<?xml version="1.0" ?>
<launch>
  <arg name="robot_ip" default="172.16.0.2"/>
  <arg name="robot" default="panda" doc="choose your robot. Possible values: [panda, fr3]"/>
  <arg name="arm_id" default="$(arg robot)" />
  <arg name="load_gripper" default="true" />
  <arg name="xacro_args" default="" />
  <arg name="sim" default="false" />
  <arg name="rviz" default="true" />
  <arg name="start_camera" default="true" />
  <arg name="camera" default="d435" doc="choose your camera. Possible values: [d435, l515]"/>


  <param name="use_sim_time" value="$(arg sim)"/>

  <param name="robot_description" command="$(find xacro)/xacro $(find nerf_teleoperation)/description/realsense_$(arg camera).urdf.xacro hand:=$(arg load_gripper) arm_id:=$(arg arm_id)"/>



  <group unless="$(arg sim)">
    <include if="$(arg start_camera)" file="$(find realsense2_camera)/launch/rs_camera.launch">
      <arg name="enable_sync" value="true"/>
      <arg name="enable_pointcloud" value="true"/>
      <arg name="align_depth" value="true"/>
      <!-- <arg name="enable_confidence" value="true"/>
      <arg name="confidence_width" value="640"/>
      <arg name="confidence_height" value="0"/>
      <arg name="confidence_fps" value="30"/> -->
      <!-- <arg name="enable_accel" value="true"/>
      <arg name="enable_gyro" value="true"/> -->

    </include>

    <!-- <include file="$(find franka_gripper)/launch/franka_gripper.launch" if="$(arg load_gripper)">
      <arg name="robot_ip" value="$(arg robot_ip)" />
      <arg name="arm_id"   value="$(arg arm_id)" />
    </include> -->

    <node name="franka_control" pkg="franka_control" type="franka_control_node" output="screen" required="true">
      <rosparam command="load" file="$(find franka_control)/config/franka_control_node.yaml" subst_value="true" />
      <param name="robot_ip" value="$(arg robot_ip)" />
    </node>
    <rosparam command="load" file="$(find franka_control)/config/default_controllers.yaml" subst_value="true" />

    <node name="state_controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" args="franka_state_controller"/>
    <node name="joint_state_publisher" type="joint_state_publisher" pkg="joint_state_publisher" output="screen">
    <rosparam if="$(arg load_gripper)" param="source_list">[franka_state_controller/joint_states, franka_gripper/joint_states] </rosparam>
    <rosparam unless="$(arg load_gripper)" param="source_list">[franka_state_controller/joint_states] </rosparam>
    <param name="rate" value="30"/>
    </node>
    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" output="screen"/>
  </group>



  <node if="$(arg rviz)" type="rviz" name="rviz" pkg="rviz" args="-d $(find nerf_teleoperation)/rviz/view.rviz" />
</launch>
