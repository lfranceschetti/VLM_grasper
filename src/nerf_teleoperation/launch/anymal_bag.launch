<?xml version="1.0" ?>

<launch>
  <arg name="load_gripper" default="true" />
  <arg name="publish_rate" default="30" />
  <!-- <arg name="robot" default="panda" doc="choose your robot. Possible values: [panda, fr3]"/> -->
  <arg name="camera" default="d435" doc="choose your camera. Possible values: [d435, l515]"/>
  <arg name="load_pcl" default="false" doc="load pointcloud"/>

  <param name="robot_description" command="$(find xacro)/xacro $(find alma_rsl_urdf)/urdf/alma.urdf.xacro"/>
  <!-- <param name="robot_description" command="$(find xacro)/xacro $(find franka_description)/robots/$(arg robot)/$(arg robot).urdf.xacro arm_id:=panda hand:=$(arg load_gripper)" /> -->
  <!-- <param name="use_sim_time" value="true" /> -->
  
  <node pkg="tf" type="static_transform_publisher" name="base_link_to_camera" args="-10.878 -6.2573 0 0 0 0 /map /origin 100" />

  <node pkg="nodelet" type="nodelet" name="nodelet_manager" args="manager" />

  <!-- start the image transport to repub the compressed image to raw -->
  <node pkg="image_transport" type="republish" name="republish" args="compressed in:=/dynaarm_REALSENSE/color/image_raw raw out:=/dynaarm_REALSENSE/color/image_raw" />

  <node pkg="nodelet" type="nodelet" name="nodelet1"
        args="load depth_image_proc/point_cloud_xyzrgb nodelet_manager">
    <remap to="/dynaarm_REALSENSE/color/camera_info" from="/rgb/camera_info"/>
    <remap to="/dynaarm_REALSENSE/color/image_raw" from="/rgb/image_rect_color"/>
    <remap to="/dynaarm_REALSENSE/aligned_depth_to_color/image_raw" from="/depth_registered/image_rect"/>
  </node>


  <!--node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" /-->
  <node pkg="rviz" type="rviz" output="screen" name="rviz" args="-d $(find nerf_teleoperation)/rviz/bag_anymal_visualization.rviz"/>
  
</launch>
