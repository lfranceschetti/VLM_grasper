<launch>

    <rosparam file="$(find vlm_grasper)/config/config.yaml" command="load"/>


    <!-- Play the rosbag file at half speed and loop indefinitely -->
    <node pkg="rosbag" type="play" name="play_bag" args="-r 0.5 -l /home/lucfra/catkin_ws/src/rosbag/pingu2.bag" />



    <!-- Start the pointcloud_creator.py node -->
    <node pkg="vlm_grasper" type="pointcloud_creator.py" name="pointcloud_creator" output="screen" />

    <!-- Start the pointcloud_transformer.py node -->
    <node pkg="vlm_grasper" type="pointcloud_transformer.py" name="pointcloud_transformer" output="screen" />

    <node pkg="vlm_grasper" type="edge_grasp.py" name="edge_grasp" output="screen" />

    <node pkg="vlm_grasper" type="grasp_image_renderer.py" name="grasp_image_renderer" output="screen" />

</launch>
